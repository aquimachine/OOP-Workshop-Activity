<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" prefHeight="559.0" prefWidth="344.0" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.topic_7.Controller">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <HBox prefHeight="27.0" prefWidth="200.0">
      <children>
         <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Name">
            <HBox.margin>
               <Insets right="30.0" />
            </HBox.margin>
         </Text>
         <TextField fx:id="txtName" />
      </children>
   </HBox>
   <HBox layoutX="30.0" layoutY="30.0" prefHeight="17.0" prefWidth="200.0">
      <children>
         <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Course">
            <HBox.margin>
               <Insets right="26.0" />
            </HBox.margin>
         </Text>
         <TextField fx:id="txtCourse" />
      </children>
   </HBox>
   <HBox layoutX="30.0" layoutY="150.0" prefHeight="27.0" prefWidth="200.0">
      <children>
         <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Year Level">
            <HBox.margin>
               <Insets right="10.0" />
            </HBox.margin>
         </Text>
         <ChoiceBox fx:id="cbYear" prefWidth="150.0" />
      </children>
   </HBox>
   <Button mnemonicParsing="false" onAction="#addStudent" text="Add" />
   <Button mnemonicParsing="false" onAction="#updateStudent" text="Update" />
   <Button mnemonicParsing="false" onAction="#deleteStudent" text="Delete" />
   <Button mnemonicParsing="false" onAction="#clearFields" text="Clear" />
   <TableView fx:id="table" prefHeight="200.0" prefWidth="200.0">
     <columns>
       <TableColumn fx:id="colId" prefWidth="75.0" text="ID" />
       <TableColumn fx:id="colName" prefWidth="75.0" text="Name" />
         <TableColumn fx:id="colCourse" prefWidth="75.0" text="Course" />
         <TableColumn fx:id="colYear" prefWidth="75.0" text="Year Level" />
     </columns>
   </TableView>
</VBox>
